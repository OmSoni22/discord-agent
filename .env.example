# === Discord AI Agent Configuration ===

# LLM Provider — using Groq (free tier, fast, great tool calling)
# Get your key at: https://console.groq.com
MODEL_PROVIDER=groq
MODEL_NAME=llama-3.3-70b-versatile
API_KEY=your-groq-api-key-here
MAX_TOKENS=4096
MAX_ITERATIONS=10
MAX_EXECUTION_TIME=60

# Discord Bot
# Get started at: https://discord.com/developers/applications
# IMPORTANT: Enable "Message Content Intent" in the bot settings
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_HISTORY_LIMIT=20
# Comma-separated channel IDs to restrict the bot; leave empty for all channels
DISCORD_ALLOWED_CHANNEL_IDS=

# Notion Integration
# Create an integration at: https://www.notion.so/my-integrations
# Then share target pages with the integration from the Notion UI
NOTION_API_KEY=your-notion-integration-token-here
# Optional: default parent page ID for new pages created without an explicit parent
NOTION_DEFAULT_PAGE_ID=

# Application
APP_NAME=Discord-Agent
DEBUG=false
LOG_LEVEL=INFO
