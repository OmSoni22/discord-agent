# === Agentic AI System Configuration ===

# Provider & Model Configuration
MODEL_PROVIDER=anthropic # Options: anthropic, google_genai, openai, ollama, etc.
MODEL_NAME=claude-3-5-sonnet-20240620
MAX_TOKENS=4096

# API Key for the chosen provider
API_KEY=your-api-key-here

# Agent Configuration
MAX_ITERATIONS=10
MAX_EXECUTION_TIME=60

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_ai

# Application
APP_NAME=Agentic-AI-System
DEBUG=true
LOG_LEVEL=INFO
